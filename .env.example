# ══════════════════════════════════════════════════════════════════════════════
# Project Sarathi AI v8.1 — Environment Configuration
# Copy this file to .env and fill in your values.
# For Google Cloud Run, these are injected via Secret Manager (see deploy.sh).
# ══════════════════════════════════════════════════════════════════════════════

# ── App Security ───────────────────────────────────────────────────────────────
SARATHI_SECRET=change_me_to_a_random_64_char_string
ADMIN_PASSWORD=SarathiAdmin@2026!

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Get from: Atlas Dashboard → Connect → Drivers → Python
# ⚠️  For Cloud Run: go to Atlas → Network Access → Add IP: 0.0.0.0/0
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sarathi_db
MONGODB_DB=sarathi_db
DB_BACKEND=mongodb

# ── Google Gemini AI ───────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
USE_GEMINI=true

# ── Google Cloud APIs (Speech-to-Text, Text-to-Speech, Translate) ─────────────
# Option A: Path to service account JSON (for local dev)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Option B: Application Default Credentials (recommended for Cloud Run)
#   gcloud auth application-default login
USE_GOOGLE_STT=false
USE_GOOGLE_TTS=false
USE_TRANSLATE=false

# ── OTP — Fast2SMS (Indian SMS gateway) ───────────────────────────────────────
# Free signup at https://www.fast2sms.com — ₹50 free credits (~400 OTPs)
FAST2SMS_API_KEY=your_fast2sms_api_key

# ── OTP — Gmail SMTP fallback ─────────────────────────────────────────────────
# Google Account → Security → 2-Step Verification → App Passwords
MAIL_EMAIL=yourgmail@gmail.com
MAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── data.gov.in — Live government data API ────────────────────────────────────
# Free API key at https://data.gov.in
DATA_GOV_API_KEY=your_data_gov_api_key

# ── Flask Environment ──────────────────────────────────────────────────────────
FLASK_ENV=development
# Set to "production" on Cloud Run (enables HTTPS-only cookies)
# Cloud Run sets this automatically via deploy.sh

# ── Google Secret Manager (production) ────────────────────────────────────────
# Automatically set by deploy.sh — do not set manually
# SECRET_MANAGER_KEY_NAME=projects/PROJECT_ID/secrets/sarathi-enc-key/versions/latest

# ── Google Cloud Project ──────────────────────────────────────────────────────
# Set automatically on Cloud Run via metadata server
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ══════════════════════════════════════════════════════════════════════════════
# MongoDB Atlas Vector Search Setup (run once after first deploy)
# ══════════════════════════════════════════════════════════════════════════════
# 1. Run: python build_scheme_index.py   (populates india_schemes collection)
# 2. Atlas UI → Search → Create Index:
#    Name: scheme_vector_index
#    Collection: sarathi_db.india_schemes
#    Field: embedding  |  Dimensions: 768  |  Similarity: cosine
# 3. Atlas UI → Atlas Search → Create Index:
#    Name: scheme_text_index
#    Collection: sarathi_db.india_schemes
#    Fields: scheme_name, eligibility, benefits, category
